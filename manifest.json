{
  "id": "./index.html",
  "name": "eFiling DocReady",
  "short_name": "DocReady",
  "description": "Merge, compress and export documents ready for SARS eFiling in seconds.",
  "lang": "en-ZA",
  "dir": "ltr",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#154734",
  "theme_color": "#154734",
  "orientation": "portrait",
  "categories": ["utilities", "productivity"],
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-maskable.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "./store-assets/screenshots/dark-mode-1.png",
      "sizes": "1536x2752",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dark mode — combine documents for SARS eFiling"
    },
    {
      "src": "./store-assets/screenshots/dark-mode-2.png",
      "sizes": "1536x2752",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dark mode — set target size and export"
    },
    {
      "src": "./store-assets/screenshots/light-mode-1.png",
      "sizes": "1536x2752",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Light mode — combine documents for SARS eFiling"
    },
    {
      "src": "./store-assets/screenshots/light-mode-2.png",
      "sizes": "1536x2752",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Light mode — set target size and export"
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "files": [
        {
          "name": "documents",
          "accept": ["application/pdf", "image/jpeg", "image/png", "image/webp", "image/*"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/pdf": [".pdf"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/png": [".png"],
        "image/webp": [".webp"]
      }
    }
  ]
}
